@page "/new-graph/{id}"

@namespace Ozds.Client.Pages

@attribute [Authorize]
@using Ozds.Business.Models
@using Ozds.Client.Shared.Models
@using Ozds.Client.Shared.Streaming
@using Ozds.Client.Shared.Charts
@using Microsoft.AspNetCore.Authorization
@inherits Ozds.Client.Base.OzdsOwningComponentBase

@if(meter is not null){
  <MeterGraph Model="@meter"/>
}

@code {

  [Parameter]
  public string Id { get; set; } = "schneider-iE3xxx-19453067";

  private IMeter? meter;

  protected override async Task OnInitializedAsync()
  {
    meter = await ScopedServices
      .GetRequiredService<OzdsMeterTableQueries>()
      .GetMeterById(Id);
  }

}
